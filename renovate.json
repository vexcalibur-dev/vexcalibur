{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/Chicago",
  "schedule": ["* 8-11 * * 1"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "enabledManagers": ["github-actions", "npm", "pep621"],
  "constraints": {
    "uv": "0.11.17"
  },
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**"
  ],
  "automergeType": "pr",
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Automerge minor and patch updates after required checks pass.",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
