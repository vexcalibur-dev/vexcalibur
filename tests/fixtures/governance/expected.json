  "organization_actions_permissions": {
    "enabled_repositories": "all",
    "sha_pinning_required": true
  },
  "organization_installations": {
    "installations": [
      {
        "app_id": 4250150,
        "app_slug": "vexcalibur-dev-automation",
        "target_type": "Organization",
        "repository_selection": "all",
        "permissions": {
          "contents": "write",
          "metadata": "read"
        },
        "suspended_at": null
      }
    ]
  },
  "organization_immutable_releases": {
    "enforced_repositories": "all"
  },
  "repositories": {
    "vexcalibur": {"default_branch": "main"},
    "vexcalibur-action": {"default_branch": "main"},
    "vexcalibur-orb": {
      "default_branch": "main",
      "allow_merge_commit": false,
      "delete_branch_on_merge": true,
      "security_and_analysis": {
        "dependabot_security_updates": {"status": "enabled"},
        "secret_scanning": {"status": "enabled"},
        "secret_scanning_push_protection": {"status": "enabled"}
      }
    },
    ".github": {
      "default_branch": "main"
    }
  },
  "orb_vulnerability_alerts_enabled": true,
  "orb_automated_security_fixes": {
    "enabled": true,
    "paused": false
  },
  "orb_private_vulnerability_reporting": {
    "enabled": true
  },
  "codeql_default_setups": {
    "vexcalibur-action": {
      "state": "configured",
      "languages": ["actions", "python"],
      "query_suite": "extended",
      "threat_model": "remote_and_local",
      "schedule": "weekly"
    },
    "vexcalibur-orb": {
      "state": "configured",
      "languages": ["actions", "python"],
      "query_suite": "extended",
      "threat_model": "remote_and_local",
      "schedule": "weekly"
    },
    ".github": {
      "state": "configured",
      "languages": ["actions"],
      "query_suite": "extended",
      "threat_model": "remote_and_local",
      "schedule": "weekly"
    }
  },
  "pypi_environment": {
    "name": "pypi",
    "can_admins_bypass": true,
    "protection_rules": [{"type": "branch_policy"}],
    "deployment_branch_policy": {
      "protected_branches": false,
      "custom_branch_policies": true
    }
  },
  "pypi_deployment_branch_policies": {
    "total_count": 1,
    "branch_policies": [{"name": "v*", "type": "tag"}]
  }
}
